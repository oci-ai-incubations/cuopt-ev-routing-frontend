{
  "name": "cuopt-frontend",
  "version": "1.0.0",
  "description": "Professional cuOPT POC Frontend with OCI Generative AI Integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run --config vitest.config.ts",
    "test:backend": "vitest run --config server/vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --coverage.provider=v8",
    "test:backend:coverage": "vitest run --config server/vitest.config.js --coverage --coverage.provider=v8 --coverage.lines=80 --coverage.functions=80 --coverage.branches=80 --coverage.statements=80",
    "audit:security": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run test:frontend && npm run test:backend:coverage && npm run audit:security",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-google-maps/api": "2.20.8",
    "@tanstack/react-query": "5.17.0",
    "axios": "1.15.1",
    "clsx": "2.1.0",
    "cors": "2.8.5",
    "date-fns": "3.2.0",
    "dotenv": "16.3.1",
    "express": "4.22.1",
    "http-proxy-middleware": "2.0.9",
    "leaflet": "1.9.4",
    "lucide-react": "0.303.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "4.2.1",
    "react-router-dom": "6.30.3",
    "recharts": "2.10.3",
    "zustand": "4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/leaflet": "1.9.8",
    "@types/node": "20.10.6",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "4.2.1",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "10.4.16",
    "concurrently": "8.2.2",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "jsdom": "27.0.1",
    "postcss": "8.4.32",
    "supertest": "7.2.2",
    "tailwindcss": "3.4.0",
    "typescript": "5.3.3",
    "typescript-eslint": "8.58.0",
    "vite": "5.4.21",
    "vitest": "3.2.4"
  }
}
