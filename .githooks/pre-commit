#!/bin/sh
# Pre-commit CI checks — runs before every commit
set -e

echo "Running pre-commit checks..."

# Lint: vite build check
echo "[1/3] Lint..."
npm run build -- --mode=production 2>&1 | tail -5
if [ $? -ne 0 ]; then echo "FAIL: lint/build"; exit 1; fi

# Tests
echo "[2/3] Tests..."
npm test
if [ $? -ne 0 ]; then echo "FAIL: tests"; exit 1; fi

# Security: npm audit
echo "[3/3] Security audit..."
npm audit --audit-level=high
if [ $? -ne 0 ]; then echo "FAIL: npm audit (high severity)"; exit 1; fi

echo "All pre-commit checks passed."
